{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "doxpro",
  "version": "0.1.0",
  "identifier": "id.projectego.doxpro",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "doxpro",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Generator dokumen bisnis: penawaran, invoice, kwitansi, proposal",
    "longDescription": "doxpro adalah aplikasi lokal-first untuk membuat surat penawaran, invoice, kwitansi, dan proposal dengan tampilan profesional. Mudah, cepat, tanpa internet."
  },
  "plugins": {
    "updater": {
      "active": false,
      "endpoints": [],
      "pubkey": ""
    }
  }
}
